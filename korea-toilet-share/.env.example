# ─────────────────────────────────────────────────────────────
# Korea Toilet Sharing Service — 환경 변수 (TRD §4)
# 설정 방법은 프로젝트 루트의 ENV_SETUP_GUIDE.md 를 참고하세요.
# 값이 비어 있어도 개발 서버는 "데모 모드"로 동작합니다.
# ─────────────────────────────────────────────────────────────

# [1] Firebase 클라이언트 설정 (Firebase 콘솔 > 프로젝트 설정 > 웹앱)
#     → 로그인 / 실제 빌딩 데이터 표시에 필요
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# [2] Firebase Admin SDK 서비스 계정 (서버 전용, 절대 커밋 금지!)
#     발급받은 JSON 파일 내용 전체를 한 줄로 붙여넣기 (작은따옴표로 감싸기)
#     → 비밀번호 열람(/api/reveal) / 제보(/api/report) / 시드 데이터에 필요
FIREBASE_ADMIN_KEY=

# [3] Kakao Developers (developers.kakao.com > 내 애플리케이션 > 앱 키)
#     → 주소 검색에 REST API 키 필요 (서버 전용)
KAKAO_REST_API_KEY=
#     → 카카오 로그인 / 카카오맵 전환 시 JavaScript 키 필요
NEXT_PUBLIC_KAKAO_JS_KEY=

# [4] 지도 프로바이더: osm(기본, 키 불필요) | kakao(Phase 2)
NEXT_PUBLIC_MAP_PROVIDER=osm

# [5] 서버 용량 신호등 기준 메모리(MB) — 기본 1024
SERVER_MEMORY_BUDGET_MB=1024
